# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxx

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_jwt
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
SUPABASE_SERVICE_KEY=xxx

# Resend
RESEND_API_KEY=re_xxx

# Security
CRON_SECRET=your-random-secret-here
MIGRATION_SECRET=your-migration-secret-here
SEED_SECRET=your-local-seed-secret-here
UNSUBSCRIBE_SECRET=your-unsubscribe-secret-here
DIGEST_LINK_SECRET=optional-digest-link-secret

# Stripe
STRIPE_SECRET_KEY=sk_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Google OAuth (Supabase provider settings)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_SUPABASE_CALLBACK_URL=https://your-project-ref.supabase.co/auth/v1/callback

# Admin access (manual scan/send actions)
ADMIN_EMAIL=admin@example.com
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# Feature flags
ENABLE_LEGACY_SUBSCRIBE=false
ALLOW_RUNTIME_MIGRATIONS=false

# App URL (for email links)
NEXT_PUBLIC_URL=http://localhost:3000
